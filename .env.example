# 디스코드 개발자 포털에서 발급받은 값들을 채워서
# 이 파일을 복사해 ".env" 로 저장하세요. (.env 는 절대 외부에 공유 금지!)

# 봇 토큰 (Bot 탭 > Reset Token)
DISCORD_TOKEN=여기에_봇_토큰_붙여넣기

# 애플리케이션 ID (General Information 탭 > Application ID)
CLIENT_ID=여기에_애플리케이션_ID

# 서버 ID (디스코드 앱에서 서버 우클릭 > "서버 ID 복사")
# 콤마(,)로 여러 서버를 넣을 수 있습니다. 비워두면 전체(글로벌) 등록.
GUILD_ID=여기에_서버_ID

# (선택) 데이터 저장 폴더. 로컬은 비워두면 됩니다.
# Railway 등 클라우드에서 볼륨을 붙였다면 그 경로(예: /data)를 넣으세요.
# DATA_DIR=/data

# (선택) 개비당 가격(원). 기본 225 (한 갑 20개비 ≈ 4,500원 기준)
# PRICE_PER_CIG=225

# (선택) 이 시간(시간 단위) 동안 아무도 안 피우면 축하 알림. 기본 3
# NO_SMOKE_ALERT_HOURS=3
